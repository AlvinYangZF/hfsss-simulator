# Ignore guest/* contents (large qcow2 / iso / fd binaries) but allow
# the cidata template source files into git. scripts/build-cidata-iso.sh
# uses the templates to rebuild guest/cidata.iso for each contributor.
guest/*
!guest/cidata/
guest/cidata/*
!guest/cidata/user-data.template
!guest/cidata/meta-data

# Coverage build output
build-cov/
*.gcno
*.gcda
.coverage-baseline.json.bak

# Investigation artifacts (runtime only)
artifacts/*
!artifacts/.gitkeep
scripts/qemu_blackbox/sweep/__pycache__/
